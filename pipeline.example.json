{
  "steps": [
    {
      "id": "scan_a",
      "enabled": true,
      "description": "OCR-Methode: rendert PDF-Seiten als Bilder und liest Text mit Tesseract.",
      "params": {
        "ocr_language": "deu+eng",
        "ocr_dpi": 300,
        "use_sidecar_fallback": true,
        "write_raw_log_file": true,
        "raw_log_file": "mein_buch.scan_a.raw.txt"
      }
    },
    {
      "id": "scan_b",
      "enabled": true,
      "description": "Schnelle Methode: extrahiert direkt den vorhandenen Textlayer aus dem PDF.",
      "params": {
        "use_sidecar_fallback": true,
        "write_raw_log_file": true,
        "raw_log_file": "mein_buch.scan_b.raw.txt"
      }
    },
    {
      "id": "reconcile_scans",
      "enabled": true,
      "description": "Gleicht Scan A und Scan B ab und erstellt daraus einen zusammengefuehrten Text.",
      "params": {}
    },
    {
      "id": "dictionary_check",
      "enabled": true,
      "description": "Prueft den Text mit Hunspell (deutsch) und rankt Korrekturen zusaetzlich mit wordfreq.",
      "params": {
        "hunspell_aff": "resources/hunspell/de_DE_frami.aff",
        "hunspell_dic": "resources/hunspell/de_DE_frami.dic",
        "wordfreq_language": "de",
        "min_similarity": 0.75,
        "use_wordfreq_ranking": true,
        "max_suggestions_to_score": 20,
        "dictionary_file": "resources/de_dictionary_sample.txt",
        "cutoff": 0.85,
        "log_top_corrections": 20,
        "write_log_file": true,
        "log_file": "mein_buch.dictionary_check.log.txt"
      }
    },
    {
      "id": "export_epub",
      "enabled": true,
      "description": "Exportiert den finalen (korrigierten) Text als EPUB-Datei.",
      "params": {
        "title": "Mein Buch",
        "author": "Unbekannt",
        "output_file": "mein_buch.epub"
      }
    },
    {
      "id": "export_txt",
      "enabled": true,
      "description": "Exportiert den finalen (korrigierten) Text als TXT-Datei.",
      "params": {
        "output_file": "mein_buch.txt"
      }
    }
  ]
}
